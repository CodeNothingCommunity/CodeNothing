// 测试长时间运行的循环，用于验证超时控制

using lib<io>;

fn main(): void {
    std::println("开始长时间循环测试...");
    
    // 创建一个会运行很多次的循环
    i : int = 0;
    while (i < 1000000) {
        // 做一些简单的计算
        j : int = i * 2;
        k : int = j + 1;
        result : int = k - i;
        
        i = i + 1;
        
        // 每10万次打印一次进度
        if (i % 100000 == 0) {
            std::println("已完成: " + i + " 次循环");
        };
    };
    
    std::println("循环测试完成！总共执行了 " + i + " 次循环");
};
