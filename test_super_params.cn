// 测试 super() 构造函数参数传递的详细测试

using lib<io>;

// 基础父类
class Animal {
    public name: string;
    public age: int;
    public species: string;

    constructor(name: string, age: int, species: string) {
        std::println("Animal 构造函数被调用");
        std::println("参数: name, age, species");
        this.name = name;
        this.age = age;
        this.species = species;
    };

    public fn getInfo(): string {
        return "Animal: " + this.name + ", " + this.age + ", " + this.species;
    };
};

class Dog extends Animal {
    public breed: string;

    constructor(name: string, age: int, breed: string) {
        std::println("Dog 构造函数开始");
        std::println("参数: name, age, breed");
        super(name, age, "Canine");
        this.breed = breed;
        std::println("Dog 构造函数完成");
    };

    public fn getInfo(): string {
        return "Dog: " + this.name + ", " + this.age + ", " + this.species + ", " + this.breed;
    };
};

class Puppy extends Dog {
    public playfulness: int;

    constructor(name: string, age: int, breed: string, playfulness: int) {
        std::println("Puppy 构造函数开始");
        std::println("参数: name, age, breed, playfulness");
        super(name, age, breed);
        this.playfulness = playfulness;
        std::println("Puppy 构造函数完成");
    };

    public fn getInfo(): string {
        return "Puppy: " + this.name + ", " + this.age + ", " + this.species + ", " + this.breed + ", playfulness=" + this.playfulness;
    };
};

fn main(): void {
    std::println("=== 详细的 super() 参数传递测试 ===");

    std::println("\n1. 测试 Animal 直接构造:");
    animal : Animal = new Animal("Generic", 5, "Unknown");
    std::println(animal.getInfo());

    std::println("\n2. 测试 Dog 构造 (调用 super 传递固定参数):");
    dog : Dog = new Dog("Buddy", 3, "Golden Retriever");
    std::println(dog.getInfo());

    std::println("\n3. 测试 Puppy 构造 (多层参数传递):");
    puppy : Puppy = new Puppy("Max", 1, "Labrador", 10);
    std::println(puppy.getInfo());

    std::println("\n=== 测试完成 ===");
};
