// 测试超时的程序 - 会运行超过30秒

using lib<io>;

fn main(): void {
    std::println("开始超时测试...");
    
    // 创建一个会运行很长时间的循环
    i : int = 0;
    while (i < 100000000) {  // 1亿次循环，应该会超过30秒
        // 做一些计算来消耗时间
        j : int = i * 2;
        k : int = j + 1;
        result : int = k - i;
        temp : int = result * 3;
        
        i = i + 1;
        
        // 每1000万次打印一次进度
        if (i % 10000000 == 0) {
            std::println("已完成: " + i + " 次循环");
        };
    };
    
    std::println("循环测试完成！总共执行了 " + i + " 次循环");
};
