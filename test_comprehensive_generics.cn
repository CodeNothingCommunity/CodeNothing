fn main(): void {
    println("=== 全面泛型系统测试 ===");

    // 测试泛型函数
    println("--- 泛型函数测试 ---");

    // 单个类型参数
    int_result : int = identity<int>(42);
    println("identity<int>(42) = ");
    println(int_result);

    string_result : string = identity<string>("hello");
    println("identity<string>(\"hello\") = ");
    println(string_result);

    bool_result : bool = identity<bool>(true);
    println("identity<bool>(true) = ");
    println(bool_result);

    // 测试swap函数
    swapped_int : int = swap<int>(10, 20);
    println("swap<int>(10, 20) = ");
    println(swapped_int);

    swapped_string : string = swap<string>("first", "second");
    println("swap<string>(\"first\", \"second\") = ");
    println(swapped_string);

    // 测试max函数
    max_int : int = max<int>(100, 50);
    println("max<int>(100, 50) = ");
    println(max_int);

    max_string : string = max<string>("apple", "banana");
    println("max<string>(\"apple\", \"banana\") = ");
    println(max_string);

    // 测试多个泛型参数的函数
    pair_result : int = pair<int, string>(123, "test");
    println("pair<int, string>(123, \"test\") = ");
    println(pair_result);

    println("=== 测试完成 ===");
};
