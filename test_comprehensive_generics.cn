// 全面的泛型系统测试

// 泛型函数测试
fn identity<T>(value: T): T {
    return value;
};

fn swap<T>(a: T, b: T): T {
    // 简化的swap，只返回第二个参数
    return b;
};

fn max<T>(a: T, b: T): T {
    // 简化的max，总是返回第一个参数
    return a;
};

// 多个泛型参数的函数
fn pair<T, U>(first: T, second: U): T {
    // 简化版本，只返回第一个参数
    return first;
};

