// CodeNothing 注释测试程序
// 测试各种注释语法

using lib<io>;

fn main() : int {
    std::println("=== 注释测试 ===");
    
    // 这是单行注释
    a : int = 5;
    
    /* 这是新的多行注释语法
       可以跨越多行
       应该被正确忽略 */
    b : int = 3;
    
    /! 这是原来的多行注释语法
       也应该正常工作 !/
    c : int = 7;
    
    // 测试字符串中的注释符号
    message : string = "这里有 // 和 /* */ 符号，但不应该被当作注释";
    std::println(message);
    
    /* 嵌套测试
       /* 内层注释 */
       外层注释继续
    */
    d : int = 9;
    
    if (a > b) {
        std::println("比较操作正常");
    };
    
    std::println("=== 注释测试完成 ===");
    return 0;
};
