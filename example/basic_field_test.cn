// 基础字段赋值测试

using lib<io>;

class Person {
    public name : string;
    public age : int;
    
    constructor(name : string, age : int) {
        this.name = name;
        this.age = age;
    };
};

fn main() : int {
    std::println("=== 字段赋值测试 ===");
    
    person : Person = new Person("Alice", 25);
    
    std::println("初始值:");
    std::println("姓名: " + person.name);
    std::println("年龄: " + person.age);
    
    // 测试字段赋值
    person.name = "Bob";
    person.age = 30;
    
    std::println("修改后:");
    std::println("姓名: " + person.name);
    std::println("年龄: " + person.age);
    
    return 0;
};
