using lib<io>;

// 斐波那契递归函数测试
fn fibonacci(n : int) : int {
    if (n <= 1) {
        return n;
    } else {
        return fibonacci(n - 1) + fibonacci(n - 2);
    };
};

fn main() : int {
    std::println("=== 斐波那契函数测试 ===");
    
    i : int = 0;
    while (i < 8) {
        fib : int = fibonacci(i);
        std::println("F(" + i + ") = " + fib);
        i = i + 1;
    };
    
    return 0;
};
