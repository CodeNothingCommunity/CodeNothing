using lib<io>;

const PI : float = 3.14159;

fn mathAbs(x : float) : float {
    if (x < 0.0) {
        return -x;
    };
    return x;
};

fn mathMax(a : float, b : float) : float {
    if (a > b) {
        return a;
    };
    return b;
};

fn mathDemo() : void {
    std::println("Math namespace Demo");
    std::println("PI = " + PI);
    
    x : float = -5.5;
    y : float = 3.2;
    std::println("abs(-5.5) = " + mathAbs(x));
    std::println("max(-5.5, 3.2) = " + mathMax(x, y));
};

fn main() : int {
    std::println("Simple Demo");
    mathDemo();
    std::println("Demo Complete");
    return 0;
};
