// CodeNothing 简单面向对象编程测试
// 测试基础的类定义、对象创建、方法调用

using lib<io>;

// 简单的 Person 类
class Person {
    public name : string;
    public age : int;
    
    // 构造函数
    constructor(name : string, age : int) {
        this.name = name;
        this.age = age;
    };
    
    // 公共方法：获取姓名
    public fn getName() : string {
        return this.name;
    };
    
    // 公共方法：获取年龄
    public fn getAge() : int {
        return this.age;
    };
    
    // 公共方法：设置年龄
    public fn setAge(newAge : int) : void {
        this.age = newAge;
    };
    
    // 公共方法：获取个人信息
    public fn getInfo() : string {
        return this.name + " (年龄: " + this.age + ")";
    };
};

// 主函数：演示基础 OOP 特性
fn main() : int {
    std::println("=== CodeNothing 简单面向对象编程测试 ===");
    
    // 1. 基础对象创建
    std::println("\n1. 创建对象:");
    person1 : Person = new Person("张三", 25);
    std::println("创建人员: " + person1.getInfo());
    
    // 2. 字段访问
    std::println("\n2. 字段访问:");
    std::println("直接访问姓名字段: " + person1.name);
    std::println("直接访问年龄字段: " + person1.age);
    
    // 3. 方法调用
    std::println("\n3. 方法调用:");
    name : string = person1.getName();
    age : int = person1.getAge();
    std::println("通过方法获取姓名: " + name);
    std::println("通过方法获取年龄: " + age);
    
    // 4. 修改对象状态
    std::println("\n4. 修改对象状态:");
    person1.setAge(26);
    std::println("设置年龄后: " + person1.getInfo());
    
    // 5. 创建多个对象
    std::println("\n5. 多个对象:");
    person2 : Person = new Person("李四", 30);
    std::println("第一个人: " + person1.getInfo());
    std::println("第二个人: " + person2.getInfo());
    
    std::println("\n=== 测试完成 ===");
    return 0;
};
