// CodeNothing 泛型符号冲突测试程序
// 测试泛型语法中的 < > 符号与比较操作符的冲突

using lib<io>;

// 测试泛型函数定义
fn compare<T>(a : T, b : T) : bool {
    // 这里应该测试泛型参数的使用
    return true;
};

// 测试泛型类定义（暂时注释掉，因为类的泛型解析尚未完全实现）
// class Container<T> {
//     public value : T;
//
//     constructor(value : T) {
//         this.value = value;
//     };
//
//     public fn getValue() : T {
//         return this.value;
